YUKARI_TIMEZONE=Asia/Jakarta
YUKARI_SQL_DIR=data/sql

OLD_DATABASE_HOST=
OLD_DATABASE_PORT=3306
OLD_DATABASE_NAME=
OLD_DATABASE_USERNAME=
OLD_DATABASE_PASSWORD=

VOUCHER_CODE_SECRET=
YUKARI_ACTION_URL=https://kyou.id/user/my-voucher

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
YUKARI_QUEUE_NAME=birthday_email_jobs
YUKARI_DISCOUNTED_WISHLIST_QUEUE_NAME=discounted_wishlist_email_jobs

# Winback (batch harian; nama queue HARUS sama dgn MAKOTO_WINBACK_QUEUE_NAME)
YUKARI_WINBACK_QUEUE_NAME=winback_email_jobs
YUKARI_WINBACK_VOUCHER_CONFIG=data/vouchers/winback.json

# Wishlist back-in (reader hanya jalan hari Jumat; nama queue HARUS sama dgn
# MAKOTO_WISHLIST_BACK_IN_QUEUE_NAME). User-centric: 1 email/user berisi item
# wishlist-nya yang restock (stock 0->>0, ready atau PO yang deadline-nya masih
# buka) dalam window 7 hari, maks 10 item/email urut restock terbaru.
# Kalau restock >10, sisanya DIBUANG (bukan carry-over) — sama seperti po-ready.
# Window dihitung otomatis dari tanggal run — tidak ada START_AT lagi.
YUKARI_WISHLIST_BACK_IN_QUEUE_NAME=wishlist_back_in_email_jobs
# Lebar window deteksi, dalam hari. Default 7 = persis satu putaran cron Jumat.
# Melebarkannya BUKAN mengejar ketertinggalan, tapi mengumumkan ulang restock
# lama: 21 hari -> 2.598 user, 90 hari -> 11.924 user & query 15,7 detik.
YUKARI_WISHLIST_BACK_IN_WINDOW_DAYS=7
# Wishlist-back-in voucher tiers. The reader picks one per user from the lowest
# GP ratio among their restocked items: >= 35% -> the 8% config, >= 25% -> the 6%
# config, below 25% -> no voucher. Each config's `amount` must equal its tier and
# its `pricing_voucher_id` must point at the head voucher with the same amount.
YUKARI_WISHLIST_BACK_IN_VOUCHER_CONFIG=data/vouchers/wishlist_back_in.json
YUKARI_WISHLIST_BACK_IN_LOW_VOUCHER_CONFIG=data/vouchers/wishlist_back_in_low.json

# PO Ready — wishlisted PO items converted to ready stock.
# Runs SATURDAY only (the reader checks the WIB weekday itself); schedule it at
# 09:00 WIB = cron `0 2 * * 6` UTC. Cron order does NOT decide priority against
# wishlist-back-in; an event gate in the two .sql files does.
# Detection window is a 7-day constant in internal/reader/po_ready.go, not an env
# var — and wishlist_back_in_user_items.sql hardcodes the same 7 days. Change both.
# Must match Makoto's MAKOTO_PO_READY_QUEUE_NAME exactly.
YUKARI_PO_READY_QUEUE_NAME=po_ready_email_jobs
